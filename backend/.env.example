NODE_ENV=development
PORT=3001
API_PREFIX=api

CORS_ORIGIN=http://localhost:3000

THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=30

LOG_LEVEL=log

# Set to "gemini" and provide a key for real LLM responses.
# Leave as "mock" to run fully offline with deterministic fake data.
LLM_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
LLM_TIMEOUT_MS=30000
