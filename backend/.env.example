NODE_ENV=development
PORT=3001
API_PREFIX=api

CORS_ORIGIN=http://localhost:3000

THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=30

LOG_LEVEL=log

# --- LLM (chat / JSON) ---
# mock: no paid APIs. openai: set OPENAI_API_KEY. gemini: set GEMINI_API_KEY.
# OPENAI_MODEL: resume analyze + job match only (not RAG embeddings).
# OPENAI_MAX_COMPLETION_TOKENS: optional; default 8192 in schema.
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_COMPLETION_TOKENS=8192
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# text-embedding-004 was deprecated Jan 14, 2026. Use gemini-embedding-001 (GA)
# or gemini-embedding-2-preview (multimodal). Both support MRL — we request
# 768-dim vectors to keep the Pinecone index small and cheap.
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=768
LLM_TIMEOUT_MS=30000

# Optional: set to 1 with GEMINI_API_KEY to enable the live API test in
# src/llm/providers/gemini.provider.spec.ts (not run in default CI).
# GEMINI_LIVE_TEST=1

# --- RAG (Pinecone retrieval) ---
# 1) RAG_ENABLED=true
# 2) PINECONE_API_KEY + PINECONE_INDEX + PINECONE_NAMESPACE (and PINECONE_HOST for serverless)
# 3) RAG_EMBEDDING_PROVIDER=openai → OPENAI_API_KEY must be set (embeddings share this key; noop if empty)
# 4) OPENAI_EMBEDDING_DIMENSIONS must equal the Pinecone index vector dimension (e.g. 3072 for text-embedding-3-large)
# 5) Run: npm --prefix backend run rag:ingest
# If queries return no evidence: lower PINECONE_MIN_SCORE (e.g. 0.35) or re-run ingest after key fixes.
RAG_ENABLED=true
RAG_EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=3072
PINECONE_API_KEY=
PINECONE_INDEX=copilot-job
# Serverless: copy host from Pinecone index details
# PINECONE_HOST=https://your-index-xxx.svc.xxx.pinecone.io
PINECONE_NAMESPACE=public-jobs
PINECONE_TOP_K=8
PINECONE_MIN_SCORE=0.45
